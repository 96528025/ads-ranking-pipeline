{
  "seed": 42,
  "num_samples": 50000,
  "test_size": 0.2,
  "features": {
    "categorical": [
      "user_segment",
      "device",
      "hour_bucket",
      "ad_category",
      "creative_type"
    ],
    "numerical": [
      "user_activity",
      "ad_quality",
      "bid"
    ]
  },
  "engineered_features": [
    "category_ctr_prior",
    "creative_ctr_prior",
    "hour_ctr_prior",
    "user_segment_ctr_prior",
    "user_ad_ctr_prior",
    "user_ad_ctr_lift",
    "category_cvr_prior",
    "creative_cvr_prior",
    "user_ad_cvr_prior",
    "user_ad_cvr_lift"
  ],
  "feature_sets": {
    "base": {
      "use_engineered_features": false
    },
    "engineered": {
      "use_engineered_features": true
    }
  },
  "training": {
    "batch_size": 512,
    "epochs": 6,
    "learning_rate": 0.001,
    "embedding_dim": 8,
    "hidden_dims": [64, 32]
  },
  "models": [
    "logistic_regression",
    "factorization_machine",
    "wide_deep",
    "deepfm"
  ],
  "ranking": {
    "group_size": 10,
    "ndcg_k": 5
  },
  "ablation": {
    "models": [
      "wide_deep",
      "deepfm"
    ]
  }
}
